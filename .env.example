# .env.example — referință variabile de mediu (NU pune secrete reale aici).
# În PRODUCȚIE, .env e SCRIS de .github/workflows/deploy.yml din GitHub Secrets la
# fiecare deploy (API_FOOTBALL_KEY, POSTGRES_URL, ANTHROPIC_API_KEY, XAI_API_KEY,
# ADMIN_API_KEY, CRON_SECRET). NU committa niciodată .env real.

# ── Secrete (injectate de deploy.yml din GitHub Secrets) ──
API_FOOTBALL_KEY=
POSTGRES_URL=postgresql://alohascan:***@localhost:5432/elefant
ANTHROPIC_API_KEY=
XAI_API_KEY=

# ── Feature flags (experimentale) ──
# NGP time-decay (de-boost ×1.2/×1.15) pe shadow determinist 10% (id%100<10).
# Default false → NGP live neschimbat. Pune-l pe `true` în GitHub Secret
# FEATURE_NGP_TIMEDECAY și redeploy pentru a porni shadow-ul. Vezi scanner.js.
FEATURE_NGP_TIMEDECAY=false
